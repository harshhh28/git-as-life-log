flowchart TB

  %% =========================
  %% MESSAGE INGESTION
  %% =========================
  subgraph Ingestion
    tgMsg[Incoming Telegram Message]

    dupCheck{Duplicate Hash<br/>Within Time Window}

    skip[Already Recorded<br/>No Write]
    callOrchestrator[Invoke Record Pipeline]
  end

  tgMsg --> dupCheck
  dupCheck -->|Duplicate| skip
  dupCheck -->|New Message| callOrchestrator

  %% =========================
  %% NOTE PROCESSING
  %% =========================
  subgraph Processing
    input[Raw Note Text]

    parseTask[LLM Parsing Task<br/>openai/gpt-oss-20b]

    parsed[Structured Metadata JSON]

    validate[Validate & Normalize Metadata]
  end

  callOrchestrator --> input
  input --> parseTask
  parseTask --> parsed
  parsed --> validate

  %% =========================
  %% DATE RESOLUTION
  %% =========================
  subgraph DateResolution
    hasDate{Contains Date Hint?}

    useToday[Use Current IST Date]

    useRelative[Resolve Relative Date<br/>today / yesterday / tomorrow]

    resolveExplicit[Extract Explicit Date]

    dateutilFallback{Explicit Extraction Success?}

    dateutilParse[Fuzzy Date Parsing]

    anchor[Anchor Start/End Time]
  end

  validate --> hasDate

  hasDate -->|No| useToday
  hasDate -->|Relative Date| useRelative
  hasDate -->|Explicit Date| resolveExplicit

  resolveExplicit --> dateutilFallback

  dateutilFallback -->|Success| anchor
  dateutilFallback -->|Fallback Needed| dateutilParse

  useToday --> anchor
  useRelative --> anchor
  dateutilParse --> anchor

  %% =========================
  %% NORMALIZATION
  %% =========================
  subgraph TimeNormalization
    normalize[Normalize to IST ISO Format]
    targetDay[Compute Target Day]
  end

  anchor --> normalize
  normalize --> targetDay

  %% =========================
  %% PATH GENERATION
  %% =========================
  subgraph PathGeneration
    dailyPath[Generate Daily Path<br/>YYYY-MM-DD]

    calPath[Generate Calendar Path<br/>YYYY-MM]
  end

  targetDay --> dailyPath
  targetDay --> calPath

  %% =========================
  %% DAILY STORAGE
  %% =========================
  subgraph DailyStorage
    ensureDaily{Daily File Exists?}

    createDaily[Create Daily Template]

    appendDaily[Append Note to Daily Log]
  end

  dailyPath --> ensureDaily

  ensureDaily -->|No| createDaily
  ensureDaily -->|Yes| appendDaily

  createDaily --> appendDaily

  %% =========================
  %% CALENDAR STORAGE
  %% =========================
  subgraph CalendarStorage
    appendCal[Append Note to Calendar File]
  end

  calPath --> appendCal

  %% =========================
  %% VERSION CONTROL
  %% =========================
  subgraph Versioning
    commit[Commit Changes to Git]

    returnResult[Return Paths, Metadata & Commit Hash]
  end

  appendDaily --> commit
  appendCal --> commit

  commit --> returnResult

  %% =========================
  %% RESPONSE FLOW
  %% =========================
  subgraph Response
    register[Register Processed Message Hash]

    output[Send Formatted Response]
  end

  returnResult --> register
  register --> output