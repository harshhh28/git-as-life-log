flowchart TB

  %% =========================
  %% INDEX BUILD TRIGGER
  %% =========================
  subgraph Trigger
    start[Index Build Trigger]
  end

  %% =========================
  %% FILE DISCOVERY
  %% =========================
  subgraph FileProcessing
    scan[Scan Markdown Files<br/>Under Life Log]

    skipTemplates[Exclude Template Files]

    chunk[Split Files Into Chunks]
  end

  start --> scan
  scan --> skipTemplates
  skipTemplates --> chunk

  %% =========================
  %% EMBEDDING PIPELINE
  %% =========================
  subgraph EmbeddingPipeline
    embedCheck{Sentence Transformer Available?}

    embed[Generate Normalized Embeddings]

    noEmbed[Store Text-Only Chunks]
  end

  chunk --> embedCheck

  embedCheck -->|Available| embed
  embedCheck -->|Unavailable| noEmbed

  %% =========================
  %% INDEX GENERATION
  %% =========================
  subgraph IndexConstruction
    makeIndex[Build Semantic Index Object]
  end

  embed --> makeIndex
  noEmbed --> makeIndex

  %% =========================
  %% PERSISTENCE
  %% =========================
  subgraph Persistence
    save[Write Semantic Index JSON]

    done[Index Ready for Retrieval]
  end

  makeIndex --> save
  save --> done