flowchart TB

  %% =========================
  %% SUMMARY TRIGGER
  %% =========================
  subgraph Trigger
    trigger[Summary Trigger<br/>UI or Scheduled Job]

    choose{Summary Period}
  end

  trigger --> choose

  %% =========================
  %% TODAY FLOW
  %% =========================
  subgraph TodaySummary
    todayRead[Read Today's Daily Log]

    todayExists{Daily File Exists?}

    noEntry[Return No Entries Found]

    todaySummarize[Generate Short Summary<br/>2–3 Sentences]

    todayResult[Return Plain Text Summary]
  end

  choose -->|Today| todayRead

  todayRead --> todayExists

  todayExists -->|No Data| noEntry
  todayExists -->|Exists| todaySummarize

  todaySummarize --> todayResult

  %% =========================
  %% RANGE COMPUTATION
  %% =========================
  subgraph RangeSelection
    weekRange[Compute Weekly Range<br/>IST]

    monthRange[Compute Monthly Range<br/>IST]
  end

  choose -->|Weekly| weekRange
  choose -->|Monthly| monthRange

  %% =========================
  %% DATA COLLECTION
  %% =========================
  subgraph DataCollection
    collect[Collect Daily Markdown Files]

    hasData{Any Entries Found?}

    fail[Return No Data Error]
  end

  weekRange --> collect
  monthRange --> collect

  collect --> hasData

  hasData -->|No| fail

  %% =========================
  %% SUMMARY GENERATION
  %% =========================
  subgraph Summarization
    summarize[Generate AI Summary<br/>Groq LLM]
  end

  hasData -->|Yes| summarize

  %% =========================
  %% OUTPUT RESOLUTION
  %% =========================
  subgraph OutputRouting
    outFile{Output Type}

    weeklyFile[Weekly Journal Path]

    monthlyFile[Monthly Journal Path]
  end

  summarize --> outFile

  outFile -->|Weekly| weeklyFile
  outFile -->|Monthly| monthlyFile

  %% =========================
  %% STORAGE & VERSIONING
  %% =========================
  subgraph Persistence
    write[Write Markdown Summary<br/>with Frontmatter]

    commit[Commit Summary to Git]

    result[Return Summary Path<br/>and Commit Hash]
  end

  weeklyFile --> write
  monthlyFile --> write

  write --> commit
  commit --> result