flowchart TB

  %% =========================
  %% QUESTION ENTRY
  %% =========================
  subgraph Input
    question[User Question]
  end

  %% =========================
  %% TODAY QUESTION PATH
  %% =========================
  subgraph TodayQuery
    todayCheck{Question About Today?}

    readToday[Read Today's Daily Log]

    todayAnswer[Return Direct High-Confidence Answer]
  end

  question --> todayCheck

  todayCheck -->|Yes| readToday
  readToday --> todayAnswer

  %% =========================
  %% WHEN-DID-I QUERY
  %% =========================
  subgraph TemporalLookup
    whenCheck{“When Did I...” Query?}

    deterministicWhen[Keyword Matching Across Logs]

    whenHit{Relevant Match Found?}

    whenResult[Return Matched Date & Context]
  end

  todayCheck -->|No| whenCheck

  whenCheck -->|Yes| deterministicWhen
  deterministicWhen --> whenHit

  whenHit -->|Yes| whenResult

  %% =========================
  %% PERSON INTERACTION QUERY
  %% =========================
  subgraph PersonLookup
    personCheck{Person Interaction Query?}

    deterministic[Deterministic Person Lookup]

    detResult[Return High-Confidence Result]
  end

  whenHit -->|No| personCheck
  whenCheck -->|No| personCheck

  personCheck -->|Yes| deterministic
  deterministic --> detResult

  %% =========================
  %% SEMANTIC SEARCH PREPARATION
  %% =========================
  subgraph RetrievalPreparation
    ragPrep[Load or Build Semantic Index]

    embedReady{Embeddings Available?}
  end

  personCheck -->|No| ragPrep

  ragPrep --> embedReady

  %% =========================
  %% VECTOR SEARCH
  %% =========================
  subgraph VectorRetrieval
    embedQuery[Encode Query Vector]

    scoreAll[Score Chunk Embeddings]

    rank[Rank Results by Similarity]
  end

  embedReady -->|Yes| embedQuery
  embedQuery --> scoreAll
  scoreAll --> rank

  %% =========================
  %% LEXICAL FALLBACK
  %% =========================
  subgraph LexicalFallback
    lexical[Compute Lexical Similarity Scores]

    scoreAllLex[Rank by Token Overlap]
  end

  embedReady -->|No| lexical
  lexical --> scoreAllLex
  scoreAllLex --> rank

  %% =========================
  %% CONTEXT BUILDING
  %% =========================
  subgraph ContextAssembly
    topk[Select Top-K Relevant Chunks]

    context[Build Evidence Context]

    addGit[Add Git History Context]
  end

  rank --> topk
  topk --> context
  context --> addGit

  %% =========================
  %% ANSWER GENERATION
  %% =========================
  subgraph AnswerGeneration
    llmAnswer[Generate Structured Answer]

    parse[Parse Structured JSON Response]

    sources[Attach Source References]

    ragResult[Return Final Search Answer]
  end

  addGit --> llmAnswer
  llmAnswer --> parse
  parse --> sources
  sources --> ragResult